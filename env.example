# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────
# Ваш API-ключ Anthropic
# Получить: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── ОПЦИОНАЛЬНО ──────────────────────────────────────────
# Порт сервера (по умолчанию 3000)
PORT=3000

# Разрешённый домен фронтенда (по умолчанию *)
# При деплое укажите точный URL: https://your-app.vercel.app
ALLOWED_ORIGIN=*
