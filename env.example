# Скопируйте этот файл в .env и заполните своими значениями
# cp .env.example .env

# ── ОБЯЗАТЕЛЬНО ──────────────────────────────────────────
# Ваш API-ключ Google Gemini (БЕСПЛАТНО)
# Получить: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy_ваш_ключ_здесь

# ── ОПЦИОНАЛЬНО ──────────────────────────────────────────
# Порт сервера (по умолчанию 3000)
PORT=3000

# Разрешённый домен фронтенда
ALLOWED_ORIGIN=*
